{
  "name": "clearstream",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Detect HLS streams on any page and play them in a clean, ad-free player.",
  "license": "MIT",
  "author": "Leonardo Braga",
  "homepage": "https://github.com/leocgbraga/clearstream#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leocgbraga/clearstream.git"
  },
  "bugs": {
    "url": "https://github.com/leocgbraga/clearstream/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "build:debug": "wxt build --mode development",
    "build:power": "CS_POWER=1 wxt build",
    "build:power:debug": "CS_POWER=1 wxt build --mode development",
    "install:store": "node scripts/install-local.mjs --store",
    "install:power": "node scripts/install-local.mjs --power",
    "install:firefox": "node scripts/install-local.mjs --firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "icons": "node scripts/gen-icons.mjs",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "node scripts/check-bundle-size.mjs",
    "audit:code": "node scripts/audit-no-remote-code.mjs",
    "check:store": "node scripts/check-store-clean.mjs",
    "lint": "eslint .",
    "lint:ext": "web-ext lint --source-dir .output/firefox-mv3 --no-config-discovery",
    "check": "pnpm compile && pnpm lint && pnpm test && pnpm build && pnpm build:firefox && pnpm build:edge && pnpm check:store && pnpm size && pnpm audit:code && pnpm lint:ext",
    "verify": "wxt build && node scripts/verify.mjs",
    "verify:firefox": "wxt build -b firefox && node scripts/verify-firefox.mjs",
    "verify:fixtures": "wxt build && node scripts/verify-fixtures.mjs",
    "verify:resolver": "pnpm build:power && node scripts/verify-resolver.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "hls.js": "1.6.16",
    "media-chrome": "4.19.2",
    "media-tracks": "0.3.5"
  },
  "devDependencies": {
    "@wxt-dev/auto-icons": "^1.1.1",
    "eslint": "^10.5.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "playwright": "^1.60.0",
    "selenium-webdriver": "^4.45.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "web-ext": "^10.4.0",
    "wxt": "^0.20.0"
  }
}
